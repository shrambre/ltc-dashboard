"s6">'&amp;body='</span><span class="s11">+</span><span class="s8">encodeURIComponent</span><span class="s1">(</span><span class="s3">text</span><span class="s1">),</span><span class="s6">'_blank'</span><span class="s1">);</span><span class="s8">toast</span><span class="s1">(</span><span class="s6">'Opening...'</span><span class="s1">,</span><span class="s6">'var(--blue2)'</span><span class="s1">);}</span><span class="s3"> </span><span class="s10">function</span><span class="s3"> </span><span class="s8">copyModule</span><span class="s1">(</span><span class="s12">id</span><span class="s1">){</span><span class="s7">navigator</span><span class="s1">.</span><span class="s3">clipboard</span><span class="s1">.</span><span class="s8">writeText</span><span class="s1">(</span><span class="s8">getModuleText</span><span class="s1">(</span><span class="s3">id</span><span class="s1">)).</span><span class="s8">then</span><span class="s1">(()</span><span class="s11">=&gt;</span><span class="s8">toast</span><span class="s1">(</span><span class="s6">'Copied!'</span><span class="s1">,</span><span class="s6">'var(--ok)'</span><span class="s1">)).</span><span class="s10">catch</span><span class="s1">(()</span><span class="s11">=&gt;</span><span class="s8">toast</span><span class="s1">(</span><span class="s6">'Select text and copy manually'</span><span class="s1">,</span><span class="s6">'var(--warm)'</span><span class="s1">));}</span><span class="s3"> </span><span class="s10">function</span><span class="s3"> </span><span class="s8">saveNotes</span><span class="s1">(){</span><span class="s10">try</span><span class="s1">{</span><span class="s7">localStorage</span><span class="s1">.</span><span class="s8">setItem</span><span class="s1">(</span><span class="s6">'ltc_road_notes'</span><span class="s1">,</span><span class="s7">document</span><span class="s1">.</span><span class="s8">getElementById</span><span class="s1">(</span><span class="s6">'road-notes'</span><span class="s1">).</span><span class="s3">value</span><span class="s1">);</span><span class="s8">toast</span><span class="s1">(</span><span class="s6">'Notes saved!'</span><span class="s1">,</span><span class="s6">'var(--gold)'</span><span class="s1">);}</span><span class="s10">catch</span><span class="s1">(</span><span class="s3">e</span><span class="s1">){}}</span><span class="s3"> </span><span class="s10">function</span><span class="s3"> </span><span class="s8">loadNotes</span><span class="s1">(){</span><span class="s10">try</span><span class="s1">{</span><span class="s10">const</span><span class="s3"> n</span><span class="s11">=</span><span class="s7">localStorage</span><span class="s1">.</span><span class="s8">getItem</span><span class="s1">(</span><span class="s6">'ltc_road_notes'</span><span class="s1">);</span><span class="s10">if</span><span class="s1">(</span><span class="s3">n</span><span class="s1">)</span><span class="s7">document</span><span class="s1">.</span><span class="s8">getElementById</span><span class="s1">(</span><span class="s6">'road-notes'</span><span class="s1">).</span><span class="s3">value</span><span class="s11">=</span><span class="s3">n</span><span class="s1">;}</span><span class="s10">catch</span><span class="s1">(</span><span class="s3">e</span><span class="s1">){}}</span><span class="s3"> </span><span class="s10">const</span><span class="s3"> </span><span class="s9">L</span><span class="s11">=</span><span class="s6">`&lt;option&gt;Doors &amp; Windows&lt;/option&gt;&lt;option&gt;Heavy Machinery&lt;/option&gt;&lt;option&gt;Advertising Signs&lt;/option&gt;&lt;option&gt;IVE / Arch. Design&lt;/option&gt;`</span><span class="s1">;</span><span class="s3"> </span><span class="s10">const</span><span class="s3"> </span><span class="s9">ST</span><span class="s11">=</span><span class="s6">`&lt;option value=""&gt;-- State --&lt;/option&gt;&lt;option&gt;NJ&lt;/option&gt;&lt;option&gt;Eastern PA&lt;/option&gt;&lt;option&gt;DE&lt;/option&gt;&lt;option&gt;MD&lt;/option&gt;&lt;option&gt;NY&lt;/option&gt;&lt;option&gt;OH&lt;/option&gt;&lt;option&gt;VA&lt;/option&gt;`</span><span class="s1">;</span><span class="s3"> </span><span class="s10">const</span><span class="s3"> </span><span class="s9">TODAY</span><span class="s11">=</span><span class="s10">new</span><span class="s3"> </span><span class="s7">Date</span><span class="s1">().</span><span class="s8">toISOString</span><span class="s1">().</span><span class="s8">slice</span><span class="s1">(</span><span class="s9">0</span><span class="s1">,</span><span class="s9">10</span><span class="s1">);</span><span class="s3"> </span><span class="s10">const</span><span class="s3"> </span><span class="s9">MODALS</span><span class="s11">=</span><span class="s1">{</span><span class="s3"> </span><span class="s4">'new-customer'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'➕ Add Customer'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="fgrid"&gt;&lt;div class="fg full"&gt;&lt;label&gt;Company Name *&lt;/label&gt;&lt;input type="text" id="c-name" placeholder="Company name"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Industry&lt;/label&gt;&lt;select id="c-industry"&gt;&lt;option&gt;Window / Door Mfg.&lt;/option&gt;&lt;option&gt;Sign Mfg.&lt;/option&gt;&lt;option&gt;Equipment / Machinery&lt;/option&gt;&lt;option&gt;Furniture / Cabinetry&lt;/option&gt;&lt;option&gt;Architecture / Design&lt;/option&gt;&lt;option&gt;Other&lt;/option&gt;&lt;/select&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Product Line&lt;/label&gt;&lt;select id="c-line"&gt;${L}&lt;/select&gt;&lt;/div&gt;&lt;div class="fg full"&gt;&lt;label&gt;Street Address&lt;/label&gt;&lt;input type="text" id="c-street" placeholder="123 Main St"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;City&lt;/label&gt;&lt;input type="text" id="c-city"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;State&lt;/label&gt;&lt;select id="c-state"&gt;${ST}&lt;/select&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Zip&lt;/label&gt;&lt;input type="text" id="c-zip"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Status&lt;/label&gt;&lt;select id="c-status"&gt;&lt;option value="prospect"&gt;Prospect&lt;/option&gt;&lt;option value="active"&gt;Active&lt;/option&gt;&lt;option value="customer"&gt;Customer&lt;/option&gt;&lt;/select&gt;&lt;/div&gt;&lt;div class="fg full"&gt;&lt;label&gt;Notes&lt;/label&gt;&lt;textarea id="c-notes" placeholder="How did you hear about them?"&gt;&lt;/textarea&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style="margin-top:12px;display:flex;gap:8px"&gt;&lt;button class="btn btn-p" onclick="saveCustomer()"&gt;Save Customer&lt;/button&gt;&lt;button class="btn btn-o" onclick="closeModal()"&gt;Cancel&lt;/button&gt;&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'new-contact'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'👤 Add Contact'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="fgrid"&gt;&lt;div class="fg"&gt;&lt;label&gt;First Name *&lt;/label&gt;&lt;input type="text" id="ct-first"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Last Name *&lt;/label&gt;&lt;input type="text" id="ct-last"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Title&lt;/label&gt;&lt;input type="text" id="ct-title" placeholder="e.g. Plant Manager"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Phone&lt;/label&gt;&lt;input type="tel" id="ct-phone"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Email&lt;/label&gt;&lt;input type="email" id="ct-email"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;State&lt;/label&gt;&lt;select id="ct-state"&gt;${ST}&lt;/select&gt;&lt;/div&gt;&lt;div class="fg full"&gt;&lt;label&gt;Street Address&lt;/label&gt;&lt;input type="text" id="ct-street" placeholder="123 Main St"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;City&lt;/label&gt;&lt;input type="text" id="ct-city"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Zip&lt;/label&gt;&lt;input type="text" id="ct-zip"&gt;&lt;/div&gt;&lt;div class="fg full"&gt;&lt;label&gt;Notes&lt;/label&gt;&lt;textarea id="ct-notes" placeholder="What do they paint?"&gt;&lt;/textarea&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style="margin-top:12px;display:flex;gap:8px"&gt;&lt;button class="btn btn-p" onclick="saveContact()"&gt;Save Contact&lt;/button&gt;&lt;button class="btn btn-o" onclick="closeModal()"&gt;Cancel&lt;/button&gt;&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'new-opportunity'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'💼 New Opportunity'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="fgrid"&gt;&lt;div class="fg"&gt;&lt;label&gt;Product Line&lt;/label&gt;&lt;select id="op-line"&gt;${L}&lt;/select&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Stage&lt;/label&gt;&lt;select id="op-stage"&gt;&lt;option value="prospect"&gt;Prospect&lt;/option&gt;&lt;option value="qualified"&gt;Qualified&lt;/option&gt;&lt;option value="demo"&gt;Demo Done&lt;/option&gt;&lt;option value="proposal"&gt;Proposal&lt;/option&gt;&lt;option value="won"&gt;Won&lt;/option&gt;&lt;/select&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Value ($)&lt;/label&gt;&lt;input type="number" id="op-value" placeholder="0"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Close Date&lt;/label&gt;&lt;input type="date" id="op-date"&gt;&lt;/div&gt;&lt;div class="fg full"&gt;&lt;label&gt;Notes&lt;/label&gt;&lt;textarea id="op-notes" placeholder="Details..."&gt;&lt;/textarea&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style="margin-top:12px;display:flex;gap:8px"&gt;&lt;button class="btn btn-p" onclick="saveOpportunity()"&gt;Save&lt;/button&gt;&lt;button class="btn btn-o" onclick="closeModal()"&gt;Cancel&lt;/button&gt;&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'log-call'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'📞 Log a Call'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="fgrid"&gt;&lt;div class="fg"&gt;&lt;label&gt;Contact Name&lt;/label&gt;&lt;input type="text" placeholder="Who did you call?"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Date&lt;/label&gt;&lt;input type="date" value="${TODAY}"&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Duration&lt;/label&gt;&lt;select&gt;&lt;option&gt;5 min&lt;/option&gt;&lt;option&gt;15 min&lt;/option&gt;&lt;option&gt;30 min&lt;/option&gt;&lt;option&gt;1 hr&lt;/option&gt;&lt;/select&gt;&lt;/div&gt;&lt;div class="fg"&gt;&lt;label&gt;Outcome&lt;/label&gt;&lt;select&gt;&lt;option&gt;Left voicemail&lt;/option&gt;&lt;option&gt;Spoke — follow up needed&lt;/option&gt;&lt;option&gt;Demo scheduled&lt;/option&gt;&lt;option&gt;Not interested&lt;/option&gt;&lt;/select&gt;&lt;/div&gt;&lt;div class="fg full"&gt;&lt;label&gt;Notes&lt;/label&gt;&lt;textarea placeholder="What was discussed?"&gt;&lt;/textarea&gt;&lt;/div&gt;&lt;div class="fg full"&gt;&lt;label&gt;Next Step&lt;/label&gt;&lt;input type="text" placeholder="e.g. Send quote by Friday"&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style="margin-top:12px;display:flex;gap:8px"&gt;&lt;button class="btn btn-p" onclick="toast('Call logged!');closeModal()"&gt;Save&lt;/button&gt;&lt;button class="btn btn-o" onclick="closeModal()"&gt;Cancel&lt;/button&gt;&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'script-signs-shop'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'📞 Script — Sign Shops'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Opening:&lt;/strong&gt;&lt;br&gt;"Hi, this is TJ — I'm the local rep for LTC Products, the exclusive North American distributor for Lechler industrial paint. Lechler is the world leader in sign paint — 10,000 colors including full Pantone matching, and custom colors in 24 to 48 hours at no extra charge. Do you have a couple minutes?"&lt;br&gt;&lt;br&gt;&lt;strong style="color:var(--gold)"&gt;Key Question:&lt;/strong&gt;&lt;br&gt;"Who are you currently buying your sign paint from, and what's your biggest frustration with it?"&lt;br&gt;&lt;br&gt;&lt;strong style="color:var(--gold)"&gt;If they mention color speed or matching:&lt;/strong&gt;&lt;br&gt;"That's exactly what we solve. Can I bring one of our technical guys in to do a demo on your actual substrates? No obligation."&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'script-mach-oem'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'📞 Script — Equipment Manufacturers'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Opening:&lt;/strong&gt;&lt;br&gt;"Hi, this is TJ — I represent LTC Products, the North American distributor for Lechler industrial paint. We work with equipment manufacturers on their painting lines — epoxy, zinc-rich, polyurethane systems. We send a technical expert to your facility to analyze your painting line and optimize your cycle. Free of charge. Is that worth 20 minutes?"&lt;br&gt;&lt;br&gt;&lt;strong style="color:var(--gold)"&gt;Key Question:&lt;/strong&gt;&lt;br&gt;"What does your current painting process look like and what are your biggest pain points?"&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'script-mach-fab'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'📞 Script — Metal Fabricators'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Opening:&lt;/strong&gt;&lt;br&gt;"Hi, this is TJ with LTC Products. We distribute Lechler industrial paint for metal and steel fabrication. Direct-to-substrate options — skip the primer on many applications — and low-VOC water-based systems that help with compliance. Are you painting your work in-house?"&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'script-ive-cabinet'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'📞 Script — Cabinet Manufacturers'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Opening:&lt;/strong&gt;&lt;br&gt;"Hi, this is TJ with LTC Products. We distribute the Lechler IVE line — Italian-developed premium finishes for MDF and wood panels. Our LWE color system matches any designer specification just-in-time, in exactly the quantity you need. No leftover paint. No color mismatches. Are you doing your own finishing?"&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'script-dw-mfg'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'📞 Script — Window &amp; Door Manufacturers'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Opening:&lt;/strong&gt;&lt;br&gt;"Hi, this is TJ — I rep LTC Products, the North American distributor for Lechler industrial paint. Direct adhesion on aluminum and PVC with no primer step. ASTM 613, 614, 615 certified, water-based and isocyanate-free. Saves time and material on every run. Are you doing your own painting?"&lt;br&gt;&lt;br&gt;&lt;strong style="color:var(--gold)"&gt;Key Question:&lt;/strong&gt;&lt;br&gt;"How are you handling color matching right now, and how consistent is it batch to batch?"&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'kb-pitch'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">"🏢 TJ's 30-Second Pitch"</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--accent)"&gt;"LTC is the exclusive North American distributor for Lechler — world leader in industrial paint for over 150 years. I cover NJ, PA, DE, and MD. We make your custom colors on-site, in exactly the quantity you need — any color in 24 to 72 hours. We direct-adhere to aluminum, PVC, vinyl, steel, MDF, glass, and more — no primer on most surfaces. We send technical experts to your shop to analyze your process and cut waste. ISO 9001 and 14000 certified, water-based, low VOC."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong&gt;Key Facts:&lt;/strong&gt;&lt;br&gt;• Territory: NJ, Eastern PA, DE, MD&lt;br&gt;• 150+ years · ISO 9001 &amp;amp; ISO 14000&lt;br&gt;• Toll-free: 1 844 417-3030 · info@ltcp.ca&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'kb-sub-pitch'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'🔬 Substrate-Based Pitch'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div style="display:flex;flex-direction:column;gap:8px"&gt;&lt;div class="ibox"&gt;&lt;strong&gt;ALUMINUM?&lt;/strong&gt; → D&amp;amp;W or Signs. "Direct adhesion, no primer, ASTM certified."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong&gt;PVC?&lt;/strong&gt; → D&amp;amp;W. "Direct adhesion, water-based, isocyanate-free."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong&gt;VINYL?&lt;/strong&gt; → Signs or D&amp;amp;W. "10,000+ colors, Pantone match, UV stable."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong&gt;STEEL?&lt;/strong&gt; → Machinery. "Epoxy, zinc-rich, or direct. Tech visits your plant."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong&gt;MDF / WOOD?&lt;/strong&gt; → IVE. "LWE system, Italian-developed. Match any designer spec."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong&gt;GLASS?&lt;/strong&gt; → IVE Vetrive. "Direct adhesion with metallic effects. Unique to Lechler."&lt;/div&gt;&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'kb-app-methods'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'🛠️ Application Methods by Substrate'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--accent)"&gt;&lt;strong&gt;🔩 ALUMINUM&lt;/strong&gt;&lt;br&gt;HVLP Spray · Electrostatic (cuts overspray 40%) · Airless/Airmix · Robot. ⚠️ Avoid roller on profiles.&lt;br&gt;&lt;span style="color:var(--gold)"&gt;Ask: "Manual spray or automated?"&lt;/span&gt;&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--accent)"&gt;&lt;strong&gt;🪟 PVC&lt;/strong&gt;&lt;br&gt;HVLP Spray · Airmix · Airless · Inverted Roll.&lt;br&gt;&lt;span style="color:var(--gold)"&gt;Ask: "Profiles or flat sheets?"&lt;/span&gt;&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--accent)"&gt;&lt;strong&gt;🎨 VINYL&lt;/strong&gt;&lt;br&gt;HVLP Spray · Airless · Inverted Roll.&lt;br&gt;&lt;span style="color:var(--gold)"&gt;Ask: "Indoor/outdoor? Rigid/flexible?"&lt;/span&gt;&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--accent)"&gt;&lt;strong&gt;⚙️ STEEL&lt;/strong&gt;&lt;br&gt;HVLP · Airless · Electrostatic · Immersion · Robot. Bare=epoxy. Corrosion=zinc-rich.&lt;br&gt;&lt;span style="color:var(--gold)"&gt;Ask: "Bare, prepped, or coated? Booth or open?"&lt;/span&gt;&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--accent)"&gt;&lt;strong&gt;🪵 MDF / WOOD&lt;/strong&gt;&lt;br&gt;HVLP · Curtain Coat · Roller · Vacuum · Airless · Robot.&lt;br&gt;&lt;span style="color:var(--gold)"&gt;Ask: "Flat panels or profiled? Line speed?"&lt;/span&gt;&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--accent)"&gt;&lt;strong&gt;🪞 GLASS&lt;/strong&gt;&lt;br&gt;HVLP ONLY. Always bring LTC technician.&lt;br&gt;&lt;span style="color:var(--gold)"&gt;Say: "Let me bring a tech to show you."&lt;/span&gt;&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'kb-5q'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'❓ 5 Questions to Ask Any New Customer'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Q1: "What are you painting?"&lt;/strong&gt; → Substrate → product line.&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Q2: "How are you applying it?"&lt;/strong&gt; → Application method.&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Q3: "What's your biggest headache with your current paint?"&lt;/strong&gt; → Pain point = your opening.&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Q4: "How much paint are you going through?"&lt;/strong&gt; → $100K+ = 🔥 escalate immediately.&lt;/div&gt;&lt;div class="ibox" style="border-left:3px solid var(--gold)"&gt;&lt;strong style="color:var(--gold)"&gt;Q5: "Who are you currently buying from?"&lt;/strong&gt; → Switching likelihood.&lt;/div&gt;&lt;div style="background:rgba(240,165,0,.07);border:1px solid rgba(240,165,0,.25);border-radius:8px;padding:11px;font-size:12px;color:var(--t2)"&gt;🎯 After 5 questions: substrate → line → method → pain → size → demo or warm lead. Log in Intel Hub immediately.&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'kb-objections'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'💬 Objections &amp; Responses'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div style="display:flex;flex-direction:column;gap:8px"&gt;&lt;div class="ibox"&gt;&lt;strong style="color:var(--err)"&gt;❓ "We have a supplier."&lt;/strong&gt;&lt;br&gt;✅ "Side-by-side demo at your shop, no cost. Let's let the paint speak."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong style="color:var(--err)"&gt;❓ "Price is higher."&lt;/strong&gt;&lt;br&gt;✅ "No primer step + zero waste + free tech support = lower total cost."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong style="color:var(--err)"&gt;❓ "Need to test first."&lt;/strong&gt;&lt;br&gt;✅ "That's exactly right. LTC technician at your facility, on your substrates."&lt;/div&gt;&lt;div class="ibox"&gt;&lt;strong style="color:var(--err)"&gt;❓ "Never heard of Lechler."&lt;/strong&gt;&lt;br&gt;✅ "150 years, world leader, ISO certified. Dominant in Europe. LTC brings it to you."&lt;/div&gt;&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'kb-colorimetry'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'🔬 Colorimetry System'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox"&gt;&lt;strong&gt;What it is:&lt;/strong&gt; Any color on demand — manufactured on-site in exact quantity.&lt;br&gt;&lt;br&gt;• Match any RAL, Pantone, or custom color&lt;br&gt;• Exact quantity — zero leftover paint&lt;br&gt;• Unique viscosity control&lt;br&gt;• Consistent batch-to-batch repeatability&lt;br&gt;&lt;br&gt;&lt;strong style="color:var(--gold)"&gt;Pitch:&lt;/strong&gt; "Do you ever have leftover paint or struggle to match a previous batch? We eliminate both."&lt;/div&gt;`</span><span class="s1">},</span><span class="s3"> </span><span class="s4">'kb-pricing'</span><span class="s11">:</span><span class="s1">{</span><span class="s4">title</span><span class="s11">:</span><span class="s6">'💰 Pricing &amp; TCO'</span><span class="s1">,</span><span class="s4">body</span><span class="s11">:</span><span class="s6">`&lt;div class="ibox"&gt;&lt;strong&gt;Total Cost of Ownership:&lt;/strong&gt;&lt;br&gt;&lt;br&gt;1. No primer step — saves material + labor&lt;br&gt;2. Zero color waste — exact quantities&lt;br&gt;3. Rework prevention — superior adhesion&lt;br&gt;4. Free technical support included&lt;br&gt;5. Environmental compliance — low VOC&lt;br&gt;&lt;br&gt;&lt;strong style="color:var(--gold)"&gt;Ask:&lt;/strong&gt; "If we cut your rework 15% and eliminated waste — what's that worth annually?"&lt;/div&gt;`</span><span class="s1">}</span><span class="s3"> </span><span class="s1">};</span><span class="s3"> </span><span class="s1">&lt;/</span><span class="s4">script</span><span class="s1">&gt;</span><span class="s3"> </span><span class="s1">&lt;/</span><span class="s4">body</span><span class="s1">&gt;</span><span class="s3"> </span><span class="s1">&lt;/</span><span class="s4">html</span><span class="s1">&gt;</span></p>
</body>
</html>
